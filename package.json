{
  "name": "st-clare-filing-system",
  "version": "1.0.0",
  "description": "Secure local-first filing desktop app for St. Clare College",
  "type": "module",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electronmon .",
    "start": "electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "electron-builder --dir",
    "dist:win": "npm run build:renderer && electron-builder --win nsis",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "generate-toc": "node index.js --generate-toc",
    "validate-fds": "node index.js --validate",
    "create-sections": "node index.js --create-sections",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "filing-system",
    "electron",
    "fds",
    "documentation",
    "template",
    "security",
    "sqlite"
  ],
  "author": "St. Clare College",
  "license": "MIT",
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.64.2",
    "archiver": "^7.0.1",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.8.1",
    "file-type": "^20.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^32.3.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.1",
    "vitest": "^3.0.9",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "ph.edu.stclare.filing-system",
    "productName": "St. Clare Filing System",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/renderer/dist/**/*",
      "src/shared/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "St. Clare Filing System"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  }
}
